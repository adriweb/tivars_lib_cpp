{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PythonAppVar",
  "type": "object",
  "definitions": {
    "hexString": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]*$"
    },
    "metadataRecord": {
      "type": "object",
      "properties": {
        "type": {
          "type": "integer",
          "minimum": 0,
          "maximum": 255
        },
        "dataHex": {
          "$ref": "#/definitions/hexString"
        },
        "name": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "length": {
          "type": "integer",
          "minimum": 1,
          "readOnly": true
        }
      },
      "required": ["type"],
      "anyOf": [
        { "required": ["dataHex"] },
        { "required": ["name"] },
        { "required": ["text"] }
      ],
      "additionalProperties": false
    }
  },
  "properties": {
    "typeName": {
      "const": "PythonAppVar"
    },
    "magic": {
      "type": "string",
      "enum": ["PYCD", "PYSC"]
    },
    "rawDataHex": {
      "$ref": "#/definitions/hexString"
    },
    "filename": {
      "type": "string"
    },
    "appendTrailingCRLF": {
      "type": "boolean"
    },
    "code": {
      "type": "string"
    },
    "script": {
      "type": "string"
    },
    "text": {
      "type": "string"
    },
    "codeHex": {
      "$ref": "#/definitions/hexString",
      "readOnly": true
    },
    "metadataRecordCount": {
      "type": "integer",
      "minimum": 0,
      "readOnly": true
    },
    "metadataRecords": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/metadataRecord"
      }
    }
  },
  "additionalProperties": false
}
