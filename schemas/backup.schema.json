{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Backup",
  "type": "object",
  "definitions": {
    "hexString": {
      "type": "string",
      "pattern": "^[0-9A-Fa-f]*$"
    }
  },
  "properties": {
    "typeName": {
      "const": "Backup"
    },
    "segmentCount": {
      "type": "integer",
      "enum": [3, 4],
      "readOnly": true
    },
    "addressOfData2": {
      "type": "integer",
      "minimum": 0,
      "maximum": 65535
    },
    "data1Length": {
      "type": "integer",
      "minimum": 0,
      "readOnly": true
    },
    "data1Hex": {
      "$ref": "#/definitions/hexString"
    },
    "data2Length": {
      "type": "integer",
      "minimum": 0,
      "readOnly": true
    },
    "data2Hex": {
      "$ref": "#/definitions/hexString"
    },
    "data3Length": {
      "type": "integer",
      "minimum": 0,
      "readOnly": true
    },
    "data3Hex": {
      "$ref": "#/definitions/hexString"
    },
    "data4Length": {
      "type": "integer",
      "minimum": 0,
      "readOnly": true
    },
    "data4Hex": {
      "$ref": "#/definitions/hexString"
    }
  },
  "required": ["data1Hex", "data2Hex", "data3Hex"],
  "additionalProperties": false
}
